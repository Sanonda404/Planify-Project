<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" styleClass="task-card" stylesheets="@../css/Todo.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.planify.frontend.controllers.task.TodoCardController">

    <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>

    <Region fx:id="priorityIndicator" styleClass="priority-indicator" />

    <!-- Header: Title & Priority Badge -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="titleLabel" styleClass="task-title" text="Task Title" wrapText="true" HBox.hgrow="ALWAYS" />
        <Label fx:id="priorityBadge" managed="false" styleClass="priority-badge" text="Medium" visible="false" />
    </HBox>

    <!-- Description Preview -->
    <Label fx:id="descriptionLabel" managed="false" styleClass="task-description" text="" visible="false" wrapText="true" />

    <!-- Meta Information -->
    <VBox spacing="8">
        <!-- Category & Milestone -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label fx:id="categoryLabel" styleClass="task-tag" text="Development" />
            <Label fx:id="milestoneLabel" managed="false" styleClass="task-tag" text="Sprint 1" visible="false" />
            <Label fx:id="dailyBadge" managed="false" styleClass="daily-badge" text="⚡ Daily Task" visible="false" />
        </HBox>

        <!-- Due Date & Project -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label fx:id="dueDateLabel" styleClass="task-meta" text="📅 No due date" />
            <Label fx:id="projectLabel" managed="false" styleClass="task-meta" text="📊 Project" visible="false" />
        </HBox>

        <!-- Assignees -->
        <HBox fx:id="assigneesBox" alignment="CENTER_LEFT" managed="false" spacing="6" visible="false">
            <Label styleClass="task-meta-label" text="Assigned:" />
            <Label fx:id="assigneesLabel" styleClass="task-meta" text="" />
        </HBox>

        <!-- Attachment -->
        <Label fx:id="attachmentLabel" managed="false" styleClass="task-attachment" text="📎 Attachment" visible="false" />

        <!-- Weight -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label fx:id="weightLabel" managed="false" styleClass="task-weight" text="⚡ Weight: 5" visible="false" />
        </HBox>
    </VBox>

    <!-- Action Button -->
    <Button fx:id="actionButton" maxWidth="Infinity" styleClass="task-action-btn" text="Start Task" />

    <!-- Quick Actions -->
    <HBox alignment="CENTER" spacing="8">
        <Button maxWidth="Infinity" onAction="#viewTask" styleClass="task-quick-btn" text="👁 View" HBox.hgrow="ALWAYS" />
        <Button maxWidth="Infinity" onAction="#editTask" styleClass="task-edit-btn" text="✏️ Edit" HBox.hgrow="ALWAYS" />
    </HBox>

</VBox>
