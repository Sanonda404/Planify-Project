<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Glow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.Region?>
<AnchorPane prefHeight="780" prefWidth="950" stylesheets="@../css/add_milestone.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.planify.frontend.controllers.project.AddMilestoneController">

    <children>
        <StackPane styleClass="am-overlay" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <VBox maxHeight="750" maxWidth="850" prefWidth="850" styleClass="am-modal">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="am-header">
                    <padding>
                        <Insets bottom="18" left="28" right="28" top="18" />
                    </padding>

                    <Label styleClass="am-header-icon" text="🏆" />
                    <Label styleClass="am-header-title" text="Add Milestone" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#closeWindow" styleClass="am-close-btn" text="×" />
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="am-scroll">
                    <content>
                        <VBox fillWidth="true" spacing="24" styleClass="am-content">
                            <padding>
                                <Insets bottom="32" left="32" right="32" top="24" />
                            </padding>

                            <!-- Milestone Name -->
                            <VBox spacing="8">
                                <Label styleClass="am-label" text="Milestone Name" />
                                <TextField fx:id="milestoneNameField" styleClass="am-textfield" promptText="Enter milestone name" />
                            </VBox>

                            <!-- Description -->
                            <VBox spacing="8">
                                <Label styleClass="am-label" text="Description" />
                                <TextArea fx:id="descriptionArea" prefRowCount="4" styleClass="am-textarea"
                                          promptText="Enter milestone description (optional)" wrapText="true" />
                            </VBox>

                            <!-- Deadline -->
                            <VBox spacing="8">
                                <Label styleClass="am-label" text="Deadline" />
                                <DatePicker fx:id="deadlinePicker" maxWidth="Infinity" styleClass="am-date-picker" promptText="Select deadline date" />
                            </VBox>

                            <Separator styleClass="am-separator" />

                            <!-- Assign Existing Tasks -->
                            <VBox spacing="12" styleClass="am-task-section">
                                <Label styleClass="am-section-title" text="📋 Assign Existing Tasks" />
                                <Label styleClass="am-section-subtitle" text="Select tasks to include in this milestone" />

                                <ScrollPane fitToWidth="true" prefHeight="280" styleClass="am-task-scroll">
                                    <VBox fx:id="taskListBox" spacing="10" styleClass="am-task-list">
                                        <Label styleClass="am-empty-tasks" text="No unassigned tasks available" />
                                    </VBox>
                                </ScrollPane>
                            </VBox>

                            <!-- Buttons -->
                            <HBox spacing="16" alignment="CENTER">
                                <Button onAction="#closeWindow" styleClass="am-cancel-btn" text="Cancel" HBox.hgrow="ALWAYS" />
                                <Button onAction="#createMilestone" styleClass="am-create-btn" text="Create Milestone" HBox.hgrow="ALWAYS" />
                            </HBox>

                        </VBox>
                    </content>
                </ScrollPane>

            </VBox>
        </StackPane>
    </children>
</AnchorPane>