<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="623.0" prefWidth="1063.0" spacing="20.0" style="-fx-background-color: #f0f8ff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.planify.frontend.controllers.SignupController"> <padding>
    <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
</padding>

    <VBox alignment="CENTER" spacing="5">
        <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0077b6;" text="Planify" />
        <Label style="-fx-font-size: 14px; -fx-text-fill: #ef476f;" text="Untangle time, unlock life" />
    </VBox>

    <VBox maxWidth="350" prefHeight="350.0" prefWidth="350.0" spacing="15" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">

        <VBox spacing="5">
            <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #666;" text="USERNAME" />
            <TextField fx:id="usernameField" promptText="Choose a unique username" />
        </VBox>

        <VBox spacing="5">
            <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #666;" text="EMAIL ADDRESS" />
            <TextField fx:id="emailField" promptText="Enter your email" />
        </VBox>

        <VBox spacing="5">
            <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #666;" text="SECURITY KEY" />
            <PasswordField fx:id="passwordField" promptText="6 to 20 characters" />
        </VBox>

        <Button maxWidth="Infinity" onAction="#handleSignup" prefHeight="40" style="-fx-background-color: #0077b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Create My Account" />

        <HBox alignment="CENTER" spacing="5">
            <Label style="-fx-font-size: 12px;" text="Already have an account?" />
            <Hyperlink onAction="#switchToLogin" style="-fx-font-size: 12px; -fx-text-fill: #0077b6;" text="Login" />
        </HBox>
      <Label fx:id="errorLabel"/>
    </VBox>
</VBox>
