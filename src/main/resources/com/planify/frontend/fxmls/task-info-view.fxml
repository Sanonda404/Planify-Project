<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="20" prefWidth="450.0" style="-fx-background-color: white; -fx-background-radius: 20;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.planify.frontend.controllers.TodoInfoController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label fx:id="statusBadge" text="IN-PROGRESS" style="-fx-background-color: #e3f2fd; -fx-text-fill: #1976d2; -fx-padding: 5 10; -fx-background-radius: 5; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="✕" onAction="#closeModal" style="-fx-background-color: transparent; -fx-font-size: 16px;"/>
            </children>
        </HBox>

        <VBox spacing="5">
            <Label fx:id="titleLabel" text="Task Title" wrapText="true">
                <font> <Font name="System Bold" size="24.0" /> </font>
            </Label>
            <Label fx:id="categoryLabel" text="Category: Study" style="-fx-text-fill: #888;" />
        </VBox>

        <Separator />

        <VBox spacing="10">
            <Label text="Description" style="-fx-font-weight: bold;" />
            <Label fx:id="descriptionLabel" text="No description provided." wrapText="true" style="-fx-text-fill: #444;" />
        </VBox>

        <HBox spacing="40">
            <VBox>
                <Label text="Due Date" style="-fx-font-weight: bold;" />
                <Label fx:id="dateLabel" text="Feb 20, 2026" />
            </VBox>
            <VBox>
                <Label text="Priority" style="-fx-font-weight: bold;" />
                <Label fx:id="priorityLabel" text="High" style="-fx-text-fill: #ef476f;" />
            </VBox>
        </HBox>

        <Button onAction="#closeModal" maxWidth="Infinity" prefHeight="40" text="Close"
                style="-fx-background-color: #f0f0f0; -fx-background-radius: 10; -fx-cursor: hand;" />
    </children>
</VBox>