<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="750" prefWidth="950" stylesheets="@../css/add_project.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.planify.frontend.controllers.project.AddProjectController">

    <children>
        <StackPane styleClass="ap-overlay" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <VBox maxHeight="720" maxWidth="860" prefWidth="860" styleClass="ap-modal">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="ap-header">
                    <padding>
                        <Insets top="18" right="24" bottom="18" left="24"/>
                    </padding>
                    <Label text="📊" styleClass="ap-header-icon"/>
                    <Label text="Create New Project" styleClass="ap-header-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#closeWindow" styleClass="ap-close-btn" text="×"/>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="ap-scroll">
                    <content>
                        <VBox spacing="24" fillWidth="true" styleClass="ap-content">
                            <padding>
                                <Insets top="28" right="32" bottom="32" left="32"/>
                            </padding>

                            <!-- Project Name -->
                            <VBox spacing="8">
                                <Label text="Project Name" styleClass="ap-label"/>
                                <TextField fx:id="taskNameField" styleClass="ap-textfield" promptText="Enter project name"/>
                            </VBox>

                            <!-- Description -->
                            <VBox spacing="8">
                                <Label text="Description" styleClass="ap-label"/>
                                <TextArea fx:id="descriptionArea" prefRowCount="4" styleClass="ap-textarea"
                                          promptText="Describe what this project is about" wrapText="true"/>
                            </VBox>

                            <Separator styleClass="ap-separator"/>

                            <!-- Project Type & Group Selection -->
                            <GridPane hgap="20" vgap="16">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                </columnConstraints>

                                <!-- Project Type -->
                                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Project Type" styleClass="ap-label"/>
                                    <ComboBox fx:id="projectTypeCombo" styleClass="ap-combo" promptText="Select project type"/>
                                </VBox>

                                <!-- Group Selection -->
                                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0" fx:id="groupSelectionContainer">
                                    <Label text="Select Group" styleClass="ap-label"/>
                                    <ComboBox fx:id="groupSelectCombo" styleClass="ap-combo" promptText="Choose a group"/>
                                </VBox>
                            </GridPane>

                            <Separator styleClass="ap-separator"/>

                            <!-- Timeline Section -->
                            <Label text="📅 Timeline" styleClass="ap-section-title"/>

                            <!-- Start Date & Time -->
                            <GridPane hgap="20" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                </columnConstraints>

                                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Start Date" styleClass="ap-label"/>
                                    <DatePicker fx:id="startDatePicker" styleClass="ap-date-picker" promptText="Select start date"/>
                                </VBox>

                                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label text="Start Time" styleClass="ap-label"/>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Spinner fx:id="startHour" styleClass="ap-time-spinner" editable="true" prefWidth="70"/>
                                        <Label text=":" styleClass="ap-time-separator"/>
                                        <Spinner fx:id="startMinute" styleClass="ap-time-spinner" editable="true" prefWidth="70"/>
                                        <ComboBox fx:id="startAmPm" styleClass="ap-ampm-combo" prefWidth="70"/>
                                    </HBox>
                                </VBox>
                            </GridPane>

                            <!-- Deadline Date & Time -->
                            <GridPane hgap="20" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                </columnConstraints>

                                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Deadline Date" styleClass="ap-label"/>
                                    <DatePicker fx:id="deadlinePicker" styleClass="ap-date-picker" promptText="Select deadline date"/>
                                </VBox>

                                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label text="Deadline Time" styleClass="ap-label"/>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Spinner fx:id="deadlineHour" styleClass="ap-time-spinner" editable="true" prefWidth="70"/>
                                        <Label text=":" styleClass="ap-time-separator"/>
                                        <Spinner fx:id="deadlineMinute" styleClass="ap-time-spinner" editable="true" prefWidth="70"/>
                                        <ComboBox fx:id="deadlineAmPm" styleClass="ap-ampm-combo" prefWidth="70"/>
                                    </HBox>
                                </VBox>
                            </GridPane>

                            <Separator styleClass="ap-separator"/>

                            <!-- Action Buttons -->
                            <HBox spacing="16" alignment="CENTER">
                                <Button onAction="#closeWindow" styleClass="ap-cancel-btn" text="Cancel" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Button onAction="#addProject" styleClass="ap-create-btn" text="Create Project" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            </HBox>

                        </VBox>
                    </content>
                </ScrollPane>

            </VBox>
        </StackPane>
    </children>
</AnchorPane>