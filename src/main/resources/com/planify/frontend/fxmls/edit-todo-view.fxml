<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="overlay-backdrop" stylesheets="@../css/EditTask.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.planify.frontend.controllers.task.EditTodoController">

    <!-- Modal Container -->
    <VBox maxHeight="750" maxWidth="850" styleClass="modal-container">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="modal-header">
            <padding>
                <Insets bottom="18" left="24" right="24" top="18" />
            </padding>
            <Label styleClass="header-icon" text="✏️" textFill="WHITE" />
            <Label styleClass="header-title" text="Edit Task" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="closeButton" onAction="#handleClose" styleClass="close-button" text="×" />
        </HBox>

        <!-- Content Area -->
        <ScrollPane fitToWidth="true" styleClass="content-scroll" VBox.vgrow="ALWAYS">
            <VBox spacing="20" styleClass="content-container">
                <padding>
                    <Insets bottom="24" left="28" right="28" top="24" />
                </padding>

                <!-- Task Name -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Task Name *" />
                    <TextField fx:id="taskNameField" promptText="Enter task name" styleClass="styled-textfield" />
                </VBox>

                <!-- Description -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Description" />
                    <TextArea fx:id="descriptionField" prefRowCount="3" promptText="Enter task description (optional)" styleClass="styled-textarea" wrapText="true" />
                </VBox>

                <!-- Type: Daily/Custom -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Task Type *" />
                    <ComboBox fx:id="typeCombo" promptText="Select task type" styleClass="styled-combobox" />
                </VBox>

                <!-- Due Date & Time -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Due Date &amp; Time *" />
                    <GridPane hgap="15" vgap="10">
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.hgrow="ALWAYS" GridPane.rowIndex="0">
                            <Label styleClass="field-label-small" text="Date" />
                            <DatePicker fx:id="dueDatePicker" promptText="Select due date" styleClass="styled-datepicker" />
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.rowIndex="0">
                            <Label styleClass="field-label-small" text="Time" />
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Spinner fx:id="dueHour" editable="true" prefWidth="70" styleClass="time-spinner" />
                                <Label styleClass="time-separator" text=":" />
                                <Spinner fx:id="dueMinute" editable="true" prefWidth="70" styleClass="time-spinner" />
                                <ComboBox fx:id="dueAmPm" prefWidth="100" styleClass="am-pm-combo" />
                            </HBox>
                        </VBox>
                  <columnConstraints>
                     <ColumnConstraints />
                     <ColumnConstraints />
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints />
                  </rowConstraints>
                    </GridPane>
                </VBox>

                <!-- Weight (1-10) -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Weight / Importance (1-10) *" />
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Slider fx:id="weightSlider" majorTickUnit="1" max="10" min="1" prefWidth="300" showTickLabels="true" showTickMarks="true" snapToTicks="true" styleClass="weight-slider" value="5" />
                        <Label fx:id="weightValueLabel" styleClass="weight-value" text="5" />
                    </HBox>
                    <Label styleClass="field-label-small" text="Higher weight = More important tasks" />
                </VBox>

                <!-- Priority -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Priority *" />
                    <ComboBox fx:id="priorityCombo" promptText="Select priority" styleClass="styled-combobox">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="High" />
                                <String fx:value="Medium" />
                                <String fx:value="Low" />
                            </FXCollections>
                        </items>
                    </ComboBox>
                </VBox>

                <!-- Category -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Category *" />
                    <ComboBox fx:id="categoryCombo" promptText="Select or create category" styleClass="styled-combobox" />

                    <!-- New Category Field -->
                    <VBox fx:id="newCategoryBox" managed="false" spacing="8" visible="false">
                        <Label styleClass="field-label-small" text="Enter new category name:" />
                        <TextField fx:id="newCategoryField" promptText="e.g., Development, Design, Testing" styleClass="styled-textfield" />
                    </VBox>
                </VBox>

                <!-- Project & Milestone (Read-only for editing) -->
                <VBox fx:id="projectMilestoneBox" managed="false" spacing="8" visible="false">
                    <Label styleClass="field-label" text="Project &amp; Milestone" />
                    <GridPane hgap="15" vgap="10">
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.hgrow="ALWAYS" GridPane.rowIndex="0">
                            <Label styleClass="field-label-small" text="Project" />
                            <TextField fx:id="projectNameField" editable="false" styleClass="styled-textfield" />
                        </VBox>
                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.rowIndex="0">
                            <Label styleClass="field-label-small" text="Milestone" />
                            <TextField fx:id="milestoneNameField" editable="false" styleClass="styled-textfield" />
                        </VBox>
                  <columnConstraints>
                     <ColumnConstraints />
                     <ColumnConstraints />
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints />
                  </rowConstraints>
                    </GridPane>
                </VBox>

                <!-- Assignees (For Project Tasks) -->
                <VBox fx:id="assigneesBox" managed="false" spacing="8" visible="false">
                    <Label styleClass="field-label" text="Assignees" />
                    <ScrollPane fitToWidth="true" maxHeight="180" prefHeight="150" styleClass="assignees-scroll">
                        <VBox fx:id="assigneesContainer" spacing="8" styleClass="assignees-container" />
                    </ScrollPane>
                </VBox>

                <!-- Attachment -->
                <VBox spacing="8">
                    <Label styleClass="field-label" text="Attachment (URL or Drive Link)" />
                    <TextField fx:id="attachmentField" promptText="https://drive.google.com/..." styleClass="styled-textfield" />
                </VBox>

            </VBox>
        </ScrollPane>

        <!-- Footer Buttons -->
        <HBox alignment="CENTER" spacing="16" styleClass="modal-footer">
            <padding>
                <Insets bottom="20" left="24" right="24" top="16" />
            </padding>
            <Button onAction="#handleClose" prefWidth="150" styleClass="cancel-button" text="Cancel" />
            <Button onAction="#handleUpdateTask" prefWidth="150" styleClass="update-button" text="Update Task" />
        </HBox>

    </VBox>
</StackPane>
