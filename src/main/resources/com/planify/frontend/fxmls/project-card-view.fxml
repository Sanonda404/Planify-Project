<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<?import javafx.scene.control.ScrollPane?>
<VBox maxWidth="1.7976931348623157E308"
      spacing="16.0"
      styleClass="project-card"
      stylesheets="@../css/projects.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.planify.frontend.controllers.project.ProjectCardController">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <children>
        <!-- Header with Title and Progress -->
        <HBox alignment="CENTER" spacing="16.0">
            <children>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="titleLabel"
                               text="Project Title"
                               styleClass="project-title"
                               wrapText="true"/>

                        <Label fx:id="descLabel"
                               text="Project description goes here"
                               styleClass="project-description"
                               wrapText="true"/>
                    </children>
                </VBox>

                <StackPane styleClass="progress-circle-container">
                    <Label fx:id="progressLabel"
                           text="0%"
                           styleClass="progress-percent"/>
                </StackPane>
            </children>
        </HBox>

        <!-- Progress Bar -->
        <ProgressBar fx:id="progressBar"
                     progress="0.0"
                     maxWidth="1.7976931348623157E308"
                     styleClass="custom-progress-bar"/>

        <!-- Stats Row -->
        <HBox spacing="16.0" alignment="CENTER">
            <children>
                <HBox spacing="8.0" alignment="CENTER" styleClass="stat-box" HBox.hgrow="ALWAYS">
                    <Label text="📋" styleClass="stat-icon"/>
                    <Label fx:id="milestoneCountLabel"
                           text="0 Milestones"
                           styleClass="stat-text"/>
                </HBox>

                <HBox spacing="8.0" alignment="CENTER" styleClass="stat-box" HBox.hgrow="ALWAYS">
                    <Label text="👥" styleClass="stat-icon"/>
                    <Label fx:id="teamCountLabel"
                           text="0 Members"
                           styleClass="stat-text"/>
                </HBox>
            </children>
        </HBox>

        <!-- Milestones Section -->
        <VBox spacing="10.0">
            <Label text="📌 Recent Milestones" styleClass="section-title"/>
            <ScrollPane fitToWidth="true"
                        prefHeight="180"
                        maxHeight="180"
                        styleClass="milestones-scroll">
                <content>
                    <GridPane fx:id="milestoneGrid"
                              hgap="10.0"
                              vgap="10.0"
                              styleClass="milestones-grid"/>
                </content>
            </ScrollPane>
        </VBox>

        <!-- Team Section -->
        <VBox spacing="10.0">
            <Label text="👥 Team Members" styleClass="section-title"/>
            <FlowPane fx:id="teamPane"
                      hgap="8.0"
                      vgap="8.0"
                      styleClass="team-container"/>
        </VBox>

        <!-- Action Button -->
        <Button fx:id="viewDetailsBtn"
                mnemonicParsing="false"
                onAction="#handleViewDetails"
                styleClass="view-details-btn"
                text="View Project Details"
                maxWidth="1.7976931348623157E308"/>
    </children>
</VBox>