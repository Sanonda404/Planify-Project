<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="24"
      fillWidth="true"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@../css/groups.css"
      styleClass="projects-root"
      fx:controller="com.planify.frontend.controllers.group.GroupProjectController">

    <HBox alignment="CENTER_LEFT">
        <Label text="🚀 Group Projects" styleClass="gm-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ New Project" styleClass="gm-add-btn" onAction="#openAddProject"/>
    </HBox>

    <VBox spacing="22" fillWidth="true" fx:id="projectsContainer"/>
</VBox>